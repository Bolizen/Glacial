{
  "name": "glacial",
  "version": "0.4.0",
  "description": "Glacial by Icefields, a local-first project safety dashboard",
  "homepage": "https://icefields.dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop:backend": "node ../scripts/desktop/desktop-development.mjs build-backend",
    "desktop:portable": "node ../scripts/desktop/desktop-development.mjs build-portable",
    "desktop:backend:plan": "node ../scripts/desktop/desktop-development.mjs build-backend --dry-run",
    "desktop:portable:plan": "node ../scripts/desktop/desktop-development.mjs build-portable --dry-run",
    "release:windows:plan": "node ../scripts/desktop/Build-SignedWindowsRelease.mjs --dry-run",
    "release:windows:signed": "node ../scripts/desktop/Build-SignedWindowsRelease.mjs",
    "test:release-signing": "node --test ../scripts/desktop/windows-signing.test.mjs",
    "test": "node --test src/apiConfig.test.js src/apiTransport.test.js src/projectRequests.test.js src/reportMarkdown.test.js src/sessionState.test.js src/dependencyTrust.test.js src/findingReviews.test.js src/trustedDependencyBaseline.test.js src/App.integration.test.js ../scripts/desktop/windows-signing.test.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "jsdom": "29.1.1"
  }
}
